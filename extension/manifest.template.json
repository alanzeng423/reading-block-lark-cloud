{
  "manifest_version": 3,
  "name": "Reading Block for Lark",
  "version": "0.1.0",
  "description": "Save articles to Lark Base and automatically schedule reading blocks on Lark Calendar.",
  "action": {
    "default_title": "Save to Reading Block",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "src/service-worker.js",
    "type": "module"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "permissions": ["activeTab", "contextMenus", "scripting", "storage"],
  "host_permissions": ["__PUBLIC_BASE_URL__/*"]
}
