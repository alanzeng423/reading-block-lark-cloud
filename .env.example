# Public build/deploy configuration used by `npm run configure`.
PUBLIC_BASE_URL=https://reading-block.example.com
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx

WORKER_NAME=reading-block-api
D1_DATABASE_NAME=reading-block-prod
D1_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DEFAULT_TIME_ZONE=Asia/Shanghai

# Optional. Defaults target overseas Lark. Set these only if you deploy against
# another compatible region, such as domestic Feishu.
# LARK_OPEN_API_BASE=https://your-open-api-host/open-apis
# LARK_AUTH_URL=https://your-account-host/open-apis/authen/v1/authorize

# Optional. If set, the Worker can serve /downloads/reading-block-lark-extension.zip from R2.
# R2_BUCKET_NAME=your-r2-bucket
